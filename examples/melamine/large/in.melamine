pair_coeff 8 8 atomistic 0.030000 2.500000
pair_coeff 8 9 atomistic 0.000000 0.000000
pair_coeff 9 9 atomistic 0.000000 0.000000

bond_style hybrid harmonic backmap/harmonic backmap/table linear 1000
bond_coeff 1 harmonic 962.001062 1.350000
bond_coeff 2 harmonic 962.001062 1.370000
bond_coeff 3 harmonic 764.000843 1.470000
bond_coeff 4 harmonic 868.000958 1.010000
bond_coeff 5 harmonic 640.000707 1.430000
bond_coeff 6 harmonic 680.000751 1.100000
bond_coeff 7 harmonic 1106.001221 0.980000
bond_coeff 8 harmonic 1106.001221 0.970000
bond_coeff 9 backmap/table cg table_b1.table ENTRY
bond_coeff 10 backmap/harmonic at 962.001062 1.350000
bond_coeff 11 backmap/harmonic at 962.001062 1.360000

angle_style hybrid harmonic backmap/harmonic
angle_coeff 1 harmonic 160.000177 115.9740
angle_coeff 2 harmonic 100.000110 122.7480
angle_coeff 3 harmonic 70.000077 117.1410
angle_coeff 4 harmonic 160.000177 112.2030
angle_coeff 5 harmonic 70.000077 109.7990
