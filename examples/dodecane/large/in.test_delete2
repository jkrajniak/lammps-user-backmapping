# Minimal test: delete CG atoms without fix_backmap
units real
atom_style full
boundary p p p

read_data dodecane.data

pair_style lj/cut 14.00
pair_coeff * * 0.1 3.5

bond_style harmonic
bond_coeff 1 800.000883 1.530000

angle_style harmonic
angle_coeff 1 126.673180 111.0000

special_bonds lj 0.0 0.0 0.0 coul 0.0 0.0 0.0

group at_atoms type 3 4
group cg_atoms type 1 2

neigh_modify delay 0 every 1 check yes

fix freeze cg_atoms setforce 0.0 0.0 0.0
fix relax at_atoms nve/limit 0.05

timestep 0.10
thermo 50

run 100

unfix relax
unfix freeze

print "Unfix done, now deleting CG..."

delete_atoms cg_atoms

print "CG deleted successfully!"
