pair_coeff 5 9 atomistic 0.000000 0.000000
pair_coeff 6 6 atomistic 0.000000 0.000000
pair_coeff 6 7 atomistic 0.000000 0.000000
pair_coeff 6 8 atomistic 0.000000 0.000000
pair_coeff 6 9 atomistic 0.000000 0.000000
pair_coeff 7 7 atomistic 0.170000 3.120000
